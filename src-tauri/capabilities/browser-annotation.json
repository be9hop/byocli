{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "browser-annotation",
  "description": "Allows embedded browser pages to return DOM annotations to BYOCLI.",
  "local": false,
  "remote": {
    "urls": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*",
      "https://*/*"
    ]
  },
  "webviews": ["browser-*"],
  "permissions": ["allow-capture-annotation"]
}
